# Packet rollback snapshots (binary, >1 GB; .md5 + .sha256 sidecars are committed for audit trail).
state/zeus-world.db.pre-p*-*
!state/zeus-world.db.pre-p*-*.md5
!state/zeus-world.db.pre-p*-*.sha256

# Backfill / rebuild scratch logs (transient nohup + tee output).
# Topology doctor walks state/ directly; active run logs are still
# classified per-file in architecture/topology.yaml, but new run logs
# should default to ignored so they don't pile up as unclassified.
state/rebuild-*.log
state/rebuild-*.out
state/fillback-*.log
state/fillback-*.out
state/hko-catchup-*.log
state/ogimet-*.log
state/wu-*.log
state/city_settlement_audit.json

# Orphan SQLite sidecars at repo root (should never exist; canonical DB is state/zeus-world.db).
/zeus-world.db-shm
/zeus-world.db-wal

# Local review / patch scratch artifacts should never become root topology surfaces.
/k_bugs.json
/patch_schema.py

.git-commit-msg.tmp

